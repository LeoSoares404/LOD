[layer_names]

2d_physics/layer_1="world"
2d_physics/layer_2="player"
2d_physics/layer_3="enemies"
2d_physics/layer_4="player_hurtbox"
2d_physics/layer_5="enemy_hurtbox"
2d_physics/layer_6="pickups"

[rendering]

; NEAREST: pixel-art nitida. Se ficar borrado, foi isto que mudou.
textures/canvas_textures/default_texture_filter=0
; Snap: elimina jitter/shimmer de sprites em posicoes fracionarias
2d/snap/snap_2d_transforms_to_pixel=true
