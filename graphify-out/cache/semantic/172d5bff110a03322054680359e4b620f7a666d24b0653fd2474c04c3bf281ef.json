{"nodes": [{"id": "erros_godot", "label": "ERROS_GODOT.md", "file_type": "document", "source_file": "ERROS_GODOT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "erros_godot_missing_id_ext_resource", "label": "Missing 'id' in ext_resource tag (root cause)", "file_type": "rationale", "source_file": "ERROS_GODOT.md", "source_location": "\u00a71", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Godot 4's text scene format requires every [ext_resource] tag to have an id, referenced in-body via ExtResource(id). This happens when .tscn files are hand-written or generated externally instead of saved by the Godot editor, which always writes id/load_steps automatically. It is the root cause of most of the reported error cascade."}, {"id": "erros_godot_affected_scenes_missing_id", "label": "Scenes Affected by Missing-ID Bug (8 .tscn files)", "file_type": "concept", "source_file": "ERROS_GODOT.md", "source_location": "\u00a71", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "erros_godot_cascading_load_failures", "label": "Cascading Load Failures", "file_type": "rationale", "source_file": "ERROS_GODOT.md", "source_location": "\u00a72", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Most of the ~30 reported errors were domino effects of the 8 malformed ext_resource tags, not independent problems."}, {"id": "erros_godot_preload_pattern", "label": "const X = preload(scene) Pattern Breaking on Load Failure", "file_type": "concept", "source_file": "ERROS_GODOT.md", "source_location": "\u00a72", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "erros_godot_main_tscn_corruption", "label": "main.tscn Marked Corrupt via ArmorMenu Dependency", "file_type": "concept", "source_file": "ERROS_GODOT.md", "source_location": "\u00a72", "source_url": null, "captured_